<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Confirmed | GlowLuxe</title>
    <link rel="stylesheet" href="/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <div class="promo-bar">
      <div class="promo-track">
        <span>✦ Free Delivery in Kigali</span>
        <span>✦ 100% Natural Ingredients</span>
        <span>✦ New Collection 2026</span>
        <span>✦ Dermatologist Tested</span>
        <span>✦ Buy 2 Get 1 Free</span>
        <span>✦ Free Delivery in Kigali</span>
        <span>✦ 100% Natural Ingredients</span>
        <span>✦ New Collection 2026</span>
        <span>✦ Dermatologist Tested</span>
        <span>✦ Buy 2 Get 1 Free</span>
      </div>
    </div>

    <nav class="navbar">
      <a href="/" class="brand"><span class="brand-icon">✦</span> GlowLuxe</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/cart" class="cart-link">🛒 Cart <span class="cart-badge">0</span></a>
      </div>
    </nav>

    <main class="confirmation-page">
      <div class="confirm-card">
        <div class="confirm-icon">✓</div>
        <span class="section-tag">Order Placed Successfully</span>
        <h1>Thank You for Your Order!</h1>
        <p class="confirm-sub">Your GlowLuxe products are being prepared with care and will be delivered to you soon.</p>

        <div class="confirm-details">
          <div class="confirm-detail-item">
            <span class="detail-label">Order Number</span>
            <span class="detail-value">#<%= orderId %></span>
          </div>
          <div class="confirm-detail-item">
            <span class="detail-label">Amount Paid</span>
            <span class="detail-value"><%= formatCurrency(total) %></span>
          </div>
          <div class="confirm-detail-item">
            <span class="detail-label">Delivery</span>
            <span class="detail-value free-tag">FREE</span>
          </div>
          <div class="confirm-detail-item">
            <span class="detail-label">Status</span>
            <span class="detail-value status-badge">Processing</span>
          </div>
        </div>

        <!-- DELIVERY MESSAGE -->
        <div class="delivery-msg">
          <div class="delivery-msg-icon">🚚</div>
          <div class="delivery-msg-body">
            <strong>Your order is confirmed!</strong>
            <p>We received your order at <span id="orderTime"></span>. Expected delivery by <span id="deliveryTime"></span>.</p>
            <p class="delivery-note">Our team will contact you shortly to confirm your delivery address.</p>
          </div>
        </div>

        <div class="confirm-steps">
          <div class="step done">
            <div class="step-icon">✓</div>
            <span>Order Placed</span>
          </div>
          <div class="step-line"></div>
          <div class="step active">
            <div class="step-icon">📦</div>
            <span>Preparing</span>
          </div>
          <div class="step-line"></div>
          <div class="step">
            <div class="step-icon">🚚</div>
            <span>On the Way</span>
          </div>
          <div class="step-line"></div>
          <div class="step">
            <div class="step-icon">🏠</div>
            <span>Delivered</span>
          </div>
        </div>

        <div class="confirm-actions">
          <a class="btn" href="/">🛍️ Continue Shopping</a>
          <a class="btn btn-outline-dark" href="/about">Learn About Us</a>
        </div>
      </div>
    </main>

    <footer class="footer">
      <p class="footer-copy">© 2026 GlowLuxe Lotion Co. All rights reserved.</p>
    </footer>

    <script>
      const now = new Date();
      const delivery = new Date(now.getTime() + 2 * 60 * 60 * 1000);
      const fmt = d => d.toLocaleTimeString('en-RW', { hour: '2-digit', minute: '2-digit' }) +
        ' on ' + d.toLocaleDateString('en-RW', { weekday: 'long', month: 'long', day: 'numeric' });
      document.getElementById('orderTime').textContent = fmt(now);
      document.getElementById('deliveryTime').textContent = fmt(delivery);
    </script>

  </body>
</html>
