<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About | GlowLuxe</title>
    <link rel="stylesheet" href="/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- PROMO BAR -->
    <div class="promo-bar">
      <div class="promo-track">
        <span>✦ Free Delivery in Kigali</span>
        <span>✦ 100% Natural Ingredients</span>
        <span>✦ New Collection 2026</span>
        <span>✦ Dermatologist Tested</span>
        <span>✦ Buy 2 Get 1 Free</span>
        <span>✦ Free Delivery in Kigali</span>
        <span>✦ 100% Natural Ingredients</span>
        <span>✦ New Collection 2026</span>
        <span>✦ Dermatologist Tested</span>
        <span>✦ Buy 2 Get 1 Free</span>
      </div>
    </div>

    <!-- NAV -->
    <nav class="navbar">
      <a href="/" class="brand">
        <span class="brand-icon">✦</span> GlowLuxe
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/cart" class="cart-link">
          🛒 Cart <span class="cart-badge"><%= cartCount %></span>
        </a>
      </div>
    </nav>

    <main>

      <!-- HERO BANNER -->
      <section class="about-hero">
        <div class="about-hero-overlay"></div>
        <img src="/images/skin2.webp" alt="About GlowLuxe" />
        <div class="about-hero-content">
          <span class="hero-tag">Our Story</span>
          <h1>Born in Rwanda.<br/>Made for Your Skin.</h1>
          <p>We believe radiant skin is not a luxury — it's a right. GlowLuxe was built to make premium skincare accessible to everyone.</p>
        </div>
      </section>

      <!-- MISSION SECTION -->
      <section class="about-mission">
        <div class="about-mission-text">
          <span class="section-tag">Who We Are</span>
          <h2>Our Mission</h2>
          <p>GlowLuxe is a Rwandan skincare brand dedicated to crafting nourishing lotions for all skin types. We combine natural African ingredients with modern dermatology to deliver products that truly work.</p>
          <p>From our humble beginnings in Kigali, we've grown into a brand trusted by thousands of customers across Rwanda — and we're just getting started.</p>
          <a href="/" class="btn" style="margin-top:1.2rem">Shop Our Products</a>
        </div>
        <div class="about-mission-img">
          <img src="/images/skin3.webp" alt="Our Mission" />
        </div>
      </section>

      <!-- VALUES -->
      <section class="about-values">
        <span class="section-tag">What We Stand For</span>
        <h2>Our Values</h2>
        <div class="values-grid">
          <div class="value-card">
            <div class="value-icon">🌿</div>
            <h3>Natural Ingredients</h3>
            <p>Every product is crafted with carefully sourced natural ingredients — no harmful chemicals, ever.</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🔬</div>
            <h3>Dermatologist Tested</h3>
            <p>All our formulas are tested and approved by certified dermatologists for safety and effectiveness.</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🌍</div>
            <h3>Made in Rwanda</h3>
            <p>Proudly Rwandan. We support local communities and source ingredients from local farmers.</p>
          </div>
          <div class="value-card">
            <div class="value-icon">💧</div>
            <h3>Deep Hydration</h3>
            <p>Our lotions are formulated for long-lasting moisture that keeps your skin glowing all day.</p>
          </div>
        </div>
      </section>

      <!-- TEAM -->
      <section class="about-team">
        <span class="section-tag">The People Behind GlowLuxe</span>
        <h2>Meet Our Team</h2>
        <div class="team-grid">
          <div class="team-card">
            <img src="/images/confy.jpg" alt="Founder" />
            <h3>CONFIANCE Iradukunda</h3>
            <span>Founder & CEO</span>
            <p>Passionate about skincare and African beauty, CONFIANCE started GlowLuxe to bring world-class lotions to Rwanda.</p>
          </div>
          <div class="team-card">
            <img src="/images/skin7.jpg" alt="Head of Product" />
            <h3>Jean-Paul Nkurunziza</h3>
            <span>Head of Product</span>
            <p>With 10 years in cosmetic chemistry, Jean-Paul leads our formulation team to create safe, effective products.</p>
          </div>
          <div class="team-card">
            <img src="/images/team3.webp" alt="Marketing Lead" />
            <h3>Diane Mukamana</h3>
            <span>Marketing Lead</span>
            <p>Diane connects GlowLuxe with customers across Rwanda through storytelling and community engagement.</p>
          </div>
        </div>
      </section>

      <!-- STATS -->
      <div class="stats-bar">
        <div class="stat"><strong>12+</strong><span>Products</span></div>
        <div class="stat"><strong>5,000+</strong><span>Happy Customers</span></div>
        <div class="stat"><strong>100%</strong><span>Natural Ingredients</span></div>
        <div class="stat"><strong>3+</strong><span>Years in Business</span></div>
      </div>

    </main>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="footer-inner">
        <div>
          <div class="brand">✦ GlowLuxe</div>
          <p>Premium lotions for radiant, healthy skin. Made with love in Rwanda.</p>
        </div>
        <div>
          <strong>Quick Links</strong>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/cart">Cart</a></li>
          </ul>
        </div>
        <div>
          <strong>Contact</strong>
          <p>Kigali, Rwanda<br/>info@glowluxe.rw<br/>+250 700 000 000</p>
        </div>
      </div>
      <p class="footer-copy">© 2026 GlowLuxe Lotion Co. All rights reserved.</p>
    </footer>

  </body>
</html>
