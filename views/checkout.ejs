<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout | GlowLuxe</title>
    <link rel="stylesheet" href="/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <div class="promo-bar">
      <div class="promo-track">
        <span>✦ Free Delivery in Kigali</span>
        <span>✦ 100% Natural Ingredients</span>
        <span>✦ New Collection 2025</span>
        <span>✦ Dermatologist Tested</span>
        <span>✦ Buy 2 Get 1 Free</span>
        <span>✦ Free Delivery in Kigali</span>
        <span>✦ 100% Natural Ingredients</span>
        <span>✦ New Collection 2025</span>
        <span>✦ Dermatologist Tested</span>
        <span>✦ Buy 2 Get 1 Free</span>
      </div>
    </div>

    <nav class="navbar">
      <a href="/" class="brand"><span class="brand-icon">✦</span> GlowLuxe</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/cart" class="cart-link">🛒 Cart <span class="cart-badge"><%= cartCount %></span></a>
      </div>
    </nav>

    <main class="checkout-page">

      <div class="page-hero">
        <span class="section-tag">Almost There</span>
        <h1>Secure Checkout</h1>
      </div>

      <div class="checkout-layout">

        <div class="checkout-form-col">
          <div class="form-card">
            <h2>📦 Delivery Information</h2>
            <form action="/checkout" method="post" class="checkout-form-inner">
              <div class="form-group">
                <label>Full Name</label>
                <input name="customerName" placeholder="e.g. Amina Uwase" required />
              </div>
              <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="customerEmail" placeholder="e.g. amina@email.com" required />
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <input name="phone" placeholder="e.g. +250 700 000 000" required />
              </div>
              <div class="form-group">
                <label>Delivery Address</label>
                <textarea name="address" rows="3" placeholder="e.g. KG 123 St, Kigali, Rwanda" required></textarea>
              </div>
              <button class="btn btn-full" type="submit">🛍️ Place Order Now</button>
            </form>
          </div>
          <div class="trust-badges">
            <div class="badge">🔒 SSL Secured</div>
            <div class="badge">🚚 Free Delivery in Kigali</div>
            <div class="badge">↩️ Easy Returns</div>
          </div>
        </div>

        <div class="checkout-summary-col">
          <div class="summary-card">
            <h2>🧴 Order Summary</h2>
            <div class="summary-lines">
              <% cart.forEach((item) => { %>
                <div class="summary-line">
                  <span><%= item.name %> × <%= item.quantity %></span>
                  <span><%= formatCurrency(item.price * item.quantity) %></span>
                </div>
              <% }) %>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-line">
              <span>Delivery</span>
              <span class="free-tag">FREE</span>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-total">
              <span>Total</span>
              <span><%= formatCurrency(total) %></span>
            </div>
          </div>
          <div class="checkout-img-wrap">
            <img src="/images/p5.jpg" alt="GlowLuxe Products" />
          </div>
        </div>

      </div>
    </main>

    <footer class="footer">
      <p class="footer-copy">© 2025 GlowLuxe Lotion Co. All rights reserved.</p>
    </footer>

  </body>
</html>
